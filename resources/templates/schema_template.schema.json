{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "oneOf": [
    {
      "required": ["template_id", "category", "sections", "source", "fingerprint"],
      "properties": {
        "$schema": { "type": "string" },
        "template_id": { "type": "string" },
        "category": { "type": "string" },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "labels"],
            "properties": {
              "name": { "type": "string" },
              "labels": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              }
            }
          }
        },
        "source": {
          "type": "object",
          "required": ["electronet_url_example"],
          "properties": {
            "electronet_url_example": { "type": "string" }
          }
        },
        "fingerprint": { "type": "string" }
      }
    },
    {
      "required": ["id", "category_gr", "cta_map_key", "cta_url", "electronet_examples", "sections"],
      "properties": {
        "$schema": { "type": "string" },
        "id": { "type": "string" },
        "category_gr": { "type": "string" },
        "cta_map_key": { "type": "string" },
        "cta_url": { "type": "string" },
        "electronet_examples": { "type": "array", "items": { "type": "string" } },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["section", "labels"],
            "properties": {
              "section": { "type": "string" },
              "labels": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            }
          },
          "minItems": 1
        }
      }
    }
  ]
}
