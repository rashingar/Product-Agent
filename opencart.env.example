# Local-only OpenCart credentials/config for wrapper scripts and Python tools.
# Keep this file out of version control.
#
# Resolution precedence is:
# 1. Explicit CLI arguments
# 2. Process environment
# 3. .secrets/opencart.env
# 4. Central compatibility defaults in tools/opencart_config.py

OPENCART_STORE_BASE="https://www.etranoulis.gr"
OPENCART_ADMIN_PATH="/ipadmin/index.php"
OPENCART_ADMIN_USER="YOUR_ADMIN_USERNAME"
OPENCART_ADMIN_PASS="YOUR_ADMIN_PASSWORD"

# Karapuz CSV Product Import profile name used by Playwright importer.
OPENCART_IMPORT_PROFILE="product_new"
