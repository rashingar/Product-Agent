{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Product-Agent Compact LLM Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product",
    "presentation"
  ],
  "properties": {
    "product": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meta_description",
        "meta_keywords",
        "name_tail_polished"
      ],
      "properties": {
        "meta_description": {
          "type": "string"
        },
        "meta_keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "name_tail_polished": {
          "type": "string"
        }
      }
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intro_html",
        "sections"
      ],
      "properties": {
        "intro_html": {
          "type": "string"
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "title",
              "body_html"
            ],
            "properties": {
              "title": {
                "type": "string"
              },
              "body_html": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
